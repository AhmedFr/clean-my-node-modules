{
  "name": "tidydisk",
  "version": "1.1.0",
  "description": "TidyDisk: macOS menu bar app that shows what your dev projects cost in disk space and reclaims it in one click",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "main": "out/main/index.js",
  "author": "Ahmed Abouelleil",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:clean": "sh scripts/dev-clean.sh",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "icon": "node scripts/make-icon.mjs",
    "demo": "node scripts/demo-data.mjs",
    "package": "electron-vite build && electron-builder --mac --dir",
    "release": "electron-vite build && bash scripts/release-mac.sh",
    "video:studio": "remotion studio video/index.ts",
    "video:render": "remotion render video/index.ts ShowcaseSquare out/showcase.mp4",
    "video:still": "remotion still video/index.ts ShowcaseSquare out/still.png --frame=130",
    "video:typecheck": "tsc --noEmit -p video/tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@remotion/cli": "^4.0.477",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "remotion": "^4.0.477",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "posthog-node": "^5.39.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semver": "^7.8.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.ahmed.tidydisk",
    "productName": "TidyDisk",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "artifactName": "tidydisk-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "releaseType": "draft"
    },
    "files": [
      "out/**"
    ]
  }
}
